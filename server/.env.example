# Campus Careers backend environment
# Copy to .env and fill in real values (do NOT commit .env)

PORT=5050

# MongoDB connection string
# Atlas example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campus_careers
# Local example: mongodb://127.0.0.1:27017/campus_careers
MONGO_URI=

# Email (nodemailer) — leave blank to disable sending
# For Gmail: create an App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Campus Careers <no-reply@campuscareers.edu>

# Frontend URL used in email links (no trailing slash)
CLIENT_URL=http://localhost:5173

# Set to "true" to log emails to console instead of sending (useful for dev)
EMAIL_PREVIEW=true
